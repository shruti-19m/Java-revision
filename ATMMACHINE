//--ATM Machine----
import java.util.Scanner;

class ATM{
   float balance;
   int PIN = 6754;

   public void checkupin(){
      System.out.println("Enter your pin:");
      Scanner sc = new Scanner(System.in);  // System capital S
      int enteredpin = sc.nextInt();
      if(enteredpin == PIN){
         menu();
      }
      else{
         System.out.println("Enter a valid pin:");
      }
   }

   public void menu(){
      System.out.println("Enter your choice: ");
      System.out.println("1. Check A/C Balance ");
      System.out.println("2. Withdraw Money ");
      System.out.println("3. Deposit Money");
      System.out.println("4. EXIT ");

      Scanner sc = new Scanner(System.in);
      int opt = sc.nextInt();

      if(opt == 1){
         checkBalance();
      }
      else if(opt==2){
         withdrawMoney();
      }
      else if(opt==3){
         depositeMoney();
      }
      else if(opt==4){
         return;
      }
      else{
         System.out.print("Enter a valid choice");
      }
   }

   public void checkBalance(){
      System.out.println("Balance: "+balance);  // lowercase b
      menu();
   }

   public void withdrawMoney(){
      System.out.println("Enter Amount to Withdraw:");
      Scanner sc = new Scanner(System.in);  // System capital S
      float amount = sc.nextFloat();
      if(amount > balance){  // lowercase b
         System.out.println("Insufficient Balance");
      }
      else{
         balance = balance - amount;  // lowercase b
         System.out.println("Money Withdraw Successful");
      }
      menu();
   }

   public void depositeMoney(){
      System.out.println("Enter the Amount: ");
      Scanner sc = new Scanner(System.in);  // System capital S
      float amount = sc.nextFloat();
      balance = balance + amount;  // lowercase b
      System.out.println("Money Deposited Successfully");
      menu();
   }
}

public class ATM_MACHINE {
   public static void main(String[] args){  // String capital S
      ATM obj = new ATM();
      obj.checkupin();
   }
}